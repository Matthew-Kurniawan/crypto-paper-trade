data/processed/walkforward/wf_*_decisions.csv
data/processed/walkforward_meta/equity/
data/processed/walkforward_meta/wfm_results.csv
data/processed/walkforward_meta/wfm_*_decisions.csv
data/processed/portfolio/*.parquet
data/processed/portfolio/*.png
data/processed/portfolio/portfolio_summary.csv
