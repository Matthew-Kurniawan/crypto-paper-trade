data/processed/insample_results_*.csv
data/processed/equity_*.parquet
data/processed/trades_*.parquet
data/processed/equity_top*.png
data/processed/plots/

# Live trading runtime files (regenerated each run; keep state out of git so
# different machines / sessions don't fight over it)
data/processed/live/state.json
data/processed/live/decisions_log.csv
data/processed/live/dashboard.html
data/processed/live/*.json
data/processed/live/*.md
!data/processed/live/.gitkeep

# Keep directory markers so the layout reproduces on fresh clone
!data/raw/.gitkeep
!data/processed/.gitkeep

